// Copy to Secrets.xcconfig (gitignored). `make gen` does this automatically
// if Secrets.xcconfig is missing.
//
// ATTIC_API_KEY may be left empty for simulator dev: DEBUG builds fall back
// to reading ~/.cache/neverend/openrouter.key on the host Mac.
// Before App Store submission, point ATTIC_API_ENDPOINT at the thin proxy
// so no key ships in the binary.
//
// Note: xcconfig treats // as a comment start, hence the $() escape in URLs.

ATTIC_API_KEY =
ATTIC_API_ENDPOINT = https:/$()/openrouter.ai/api/v1/chat/completions
ATTIC_MODEL = google/gemini-2.5-flash-image
